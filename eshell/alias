alias awsprod export AWS_PROFILE=ezprod && echo Switched to ezprod
alias knscur kubectl config view --minify | grep namespace
alias kns kubectl config set-context --current --namespace $1
alias kcur kubectl config current-context
alias kuse kubectl config use-context $1
alias kctx kubectl config get-contexts
alias k kubectl $*
alias netstat netstat -anv $*
alias ll ls -l $*
alias ff for i in ${eshell-flatten-list $*} {find-file $i}
alias docker-psf docker ps --filter volume=/data --format "table {{.ID}}\t{{.Image}}\t{{.Command}}\t{{.Status}}\t{{.Ports}}\t{{.Names}}"
